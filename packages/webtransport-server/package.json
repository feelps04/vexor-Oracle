{
  "name": "vexor-webtransport-server",
  "version": "1.0.0",
  "description": "WebTransport server for real-time price data with unreliable datagrams",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:geckos": "node dist/index-geckos.js",
    "start:bridge": "node dist/index-mt5-bridge.js",
    "start:ws": "node dist/index-ws.js",
    "start:udp": "node dist/index-udp.js",
    "dev": "tsc && node dist/index.js",
    "dev:geckos": "tsc && node dist/index-geckos.js",
    "dev:bridge": "tsc && node dist/index-mt5-bridge.js",
    "dev:ws": "tsc && node dist/index-ws.js",
    "dev:udp": "tsc && node dist/index-udp.js"
  },
  "dependencies": {
    "@fails-components/webtransport": "^1.5.3",
    "@geckos.io/client": "^3.0.0",
    "@geckos.io/server": "^3.0.0",
    "csv-parse": "^5.5.0",
    "fs-extra": "^11.2.0",
    "koffi": "^2.15.1",
    "node-forge": "^1.3.1",
    "redis": "^5.11.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.10.0",
    "@types/node-forge": "^1.3.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18 <22"
  }
}
